body {
    font-family: Arial, sans-serif;
    max-width: 800px;
    margin: 50px auto;
    padding: 20px;
    background-color: red;
}

h1 {
    color: #62a0cc;
    text-align: center;
}

p {
    color: #4fbd49;
    line-height: 1.8;
    display: block;
    text-align: center;
}

b {
    color: #ff1900;
    display: block;
    text-align: center;
}

i {
    color: #3498db;
    display: block;
    text-align: center;
}

img {
    max-width: 100%;
    border-radius: 10px;
    margin: 20px 0;
}
